@page
@model DocAI.Web.Pages.Docs.UploadAndProcessPageModel

@{
    ViewData["Title"] = "Upload and Process";
}

<!-- Page Header -->
<section class="docai-hero" style="padding: 2.5rem 0 3.5rem;">
    <div class="container-xl">
        <div class="docai-hero-badge mb-3">
            <i class="fa-solid fa-robot"></i> Multi-Agent Processing
        </div>
        <h1 class="h2 mb-2">Upload &amp; Process with AI Agents</h1>
        <p class="lead mb-0" style="opacity:.85;">
            Upload a PDF or select from existing files to extract, analyze, and validate content using the multi-agent pipeline.
        </p>
    </div>
</section>

<section class="py-5">
    <div class="container-xl">
        
        <!-- Alert Messages -->
        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show d-flex align-items-center gap-2 mb-4" role="alert">
                <i class="fa-solid fa-circle-check"></i>
                <span>@TempData["SuccessMessage"]</span>
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        }

        @if (Model.ErrorMessage != null)
        {
            <div class="alert alert-danger alert-dismissible fade show d-flex align-items-center gap-2 mb-4" role="alert">
                <i class="fa-solid fa-circle-exclamation"></i>
                <span>@Model.ErrorMessage</span>
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        }

        <!-- Top Row: Upload and File List Side by Side -->
        <div class="row g-4 mb-4">
            <!-- Upload New File Card -->
            <div class="col-lg-6">
                <div class="docai-card p-4 h-100">
                    <h5 class="fw-semibold mb-1 d-flex align-items-center">
                        <i class="fa-solid fa-cloud-arrow-up me-2 text-docai"></i>
                        <span>Upload New File</span>
                    </h5>
                    <p class="text-muted small mb-4">PDF files up to 6 GB</p>

                    <form method="post" asp-page-handler="Upload" enctype="multipart/form-data" id="uploadForm">
                        <div id="dropZone" class="docai-dropzone mb-3" role="button" tabindex="0">
                            <div class="docai-dropzone-icon">
                                <i class="fa-solid fa-file-pdf fa-2x text-danger"></i>
                            </div>
                            <p class="docai-dropzone-primary mb-1">Drop PDF here</p>
                            <p class="docai-dropzone-secondary mb-3">or click to browse</p>
                            <input id="FormFile" name="FormFile" type="file" accept=".pdf" class="docai-dropzone-input" />
                            <div id="filePreview" class="docai-file-preview d-none">
                                <i class="fa-solid fa-file-pdf text-danger me-2"></i>
                                <span id="fileName" class="fw-medium"></span>
                                <button type="button" id="clearFile" class="btn-close btn-close-sm ms-2" aria-label="Remove"></button>
                            </div>
                        </div>
                        <button id="uploadBtn" type="submit" class="btn btn-docai-primary w-100" disabled>
                            <i class="fa-solid fa-upload me-2"></i>Upload File
                        </button>
                    </form>
                </div>
            </div>

            <!-- Uploaded Files Card -->
            <div class="col-lg-6">
                <div class="docai-card p-4 h-100">
                    <h5 class="fw-semibold mb-3 d-flex align-items-center">
                        <i class="fa-solid fa-folder-open me-2 text-docai"></i>
                        <span>Uploaded Files</span>
                        <span class="badge bg-secondary ms-auto">@Model.UploadedFiles.Count</span>
                    </h5>
                    
                    @if (Model.UploadedFiles.Any())
                    {
                        <div class="list-group list-group-flush" id="fileList">
                            @foreach (var file in Model.UploadedFiles)
                            {
                                <div class="list-group-item list-group-item-action file-item" data-filename="@file.Name">
                                    <div class="d-flex align-items-center">
                                        <i class="fa-solid fa-file-pdf text-danger me-3"></i>
                                        <div class="flex-grow-1 text-truncate">
                                            <div class="fw-medium text-truncate small">@file.Name.Replace(file.Extension, "")</div>
                                            <small class="text-muted">@(file.Length / 1024) KB • @file.LastWriteTime.ToString("g")</small>
                                        </div>
                                    </div>
                                </div>
                            }
                        </div>
                        <div class="mt-3">
                            <button type="button" class="btn btn-success w-100" id="processSelectedBtn" disabled>
                                <i class="fa-solid fa-gears me-2"></i>Process Selected File
                            </button>
                        </div>
                    }
                    else
                    {
                        <div class="text-center text-muted py-4">
                            <i class="fa-solid fa-inbox fa-2x mb-2 opacity-50"></i>
                            <p class="small mb-0">No files uploaded yet</p>
                        </div>
                    }
                </div>
            </div>
        </div>

        <!-- Bottom Row: Processing Info and Results -->
        <div class="row g-4">
            <div class="col-12">
                
                <!-- Processing Info -->
                <div id="processingIndicator" class="d-none">
                    <div class="docai-progress-container">
                        <h5 class="fw-semibold mb-4 text-center">
                            <i class="fa-solid fa-robot me-2 text-docai"></i>Processing Document
                        </h5>
                        
                        <div class="docai-progress-steps">
                            <div class="docai-progress-step completed" id="step-upload">
                                <div class="docai-progress-step-circle">
                                    <i class="fa-solid fa-check"></i>
                                </div>
                                <div class="docai-progress-step-label">Upload</div>
                            </div>
                            <div class="docai-progress-step active" id="step-extract">
                                <div class="docai-progress-step-circle">
                                    <div class="spinner-border spinner-border-sm"></div>
                                </div>
                                <div class="docai-progress-step-label">PDF Reader</div>
                            </div>
                            <div class="docai-progress-step" id="step-analyze">
                                <div class="docai-progress-step-circle">3</div>
                                <div class="docai-progress-step-label">Analyzer</div>
                            </div>
                            <div class="docai-progress-step" id="step-validate">
                                <div class="docai-progress-step-circle">4</div>
                                <div class="docai-progress-step-label">Validator</div>
                            </div>
                            <div class="docai-progress-step" id="step-complete">
                                <div class="docai-progress-step-circle">5</div>
                                <div class="docai-progress-step-label">Complete</div>
                            </div>
                        </div>
                        
                        <div class="docai-progress-status">
                            <h6 id="progressTitle">PDF Reader Agent Working</h6>
                            <p id="progressDescription">Extracting text and analyzing document structure and quality...</p>
                        </div>
                    </div>
                </div>

                <!-- Results Display -->
                @if (Model.ProcessedData != null)
                {
                    <div class="docai-card p-4 mb-4">
                        <div class="d-flex align-items-center justify-content-between mb-3">
                            <h5 class="fw-semibold mb-0">
                                <i class="fa-solid fa-chart-pie me-2 text-docai"></i>Processing Results
                            </h5>
                            <form method="post" asp-page-handler="ClearResults" class="d-inline">
                                <button type="submit" class="btn btn-sm btn-outline-secondary">
                                    <i class="fa-solid fa-xmark me-1"></i>Clear
                                </button>
                            </form>
                        </div>

                        <!-- Stats Cards -->
                        <div class="row g-3 mb-4">
                            <div class="col-md-3">
                                <div class="stat-card">
                                    <div class="stat-icon"><i class="fa-solid fa-users"></i></div>
                                    <div class="stat-value">@Model.ProcessedData.Persons.Count</div>
                                    <div class="stat-label">Persons</div>
                                </div>
                            </div>
                            <div class="col-md-3">
                                <div class="stat-card">
                                    <div class="stat-icon"><i class="fa-solid fa-envelope"></i></div>
                                    <div class="stat-value">@Model.ProcessedData.Emails.Count</div>
                                    <div class="stat-label">Emails</div>
                                </div>
                            </div>
                            <div class="col-md-3">
                                <div class="stat-card">
                                    <div class="stat-icon"><i class="fa-solid fa-table"></i></div>
                                    <div class="stat-value">@Model.ProcessedData.Tables.Count</div>
                                    <div class="stat-label">Tables</div>
                                </div>
                            </div>
                            <div class="col-md-3">
                                <div class="stat-card">
                                    <div class="stat-icon"><i class="fa-solid fa-file"></i></div>
                                    <div class="stat-value">@Model.ProcessedData.Metadata["PageCount"]</div>
                                    <div class="stat-label">Pages</div>
                                </div>
                            </div>
                        </div>

                        <!-- Validation Results -->
                        @if (Model.ValidationResult != null)
                        {
                            <div class="mb-4">
                                <h6 class="fw-semibold mb-3"><i class="fa-solid fa-check-circle me-2 text-success"></i>Validation Summary</h6>
                                <div class="row g-2">
                                    <div class="col-md-4">
                                        <div class="validation-badge validation-valid">
                                            <i class="fa-solid fa-check-circle me-2"></i>
                                            <span>@Model.ValidationResult.ValidItems.Count Valid</span>
                                        </div>
                                    </div>
                                    <div class="col-md-4">
                                        <div class="validation-badge validation-invalid">
                                            <i class="fa-solid fa-times-circle me-2"></i>
                                            <span>@Model.ValidationResult.InvalidItems.Count Invalid</span>
                                        </div>
                                    </div>
                                    <div class="col-md-4">
                                        <div class="validation-badge validation-unconfirmed">
                                            <i class="fa-solid fa-question-circle me-2"></i>
                                            <span>@Model.ValidationResult.UnconfirmedItems.Count Unconfirmed</span>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        }

                        <!-- Accordion for Detailed Data -->
                        <div class="accordion" id="dataAccordion">
                            @if (Model.ProcessedData.Persons.Any())
                            {
                                <div class="accordion-item">
                                    <h2 class="accordion-header">
                                        <button class="accordion-button" type="button" data-bs-toggle="collapse" data-bs-target="#personsCollapse">
                                            <i class="fa-solid fa-users me-2"></i>Persons (@Model.ProcessedData.Persons.Count)
                                        </button>
                                    </h2>
                                    <div id="personsCollapse" class="accordion-collapse collapse show" data-bs-parent="#dataAccordion">
                                        <div class="accordion-body">
                                            @foreach (var person in Model.ProcessedData.Persons)
                                            {
                                                <div class="data-item">
                                                    <div class="fw-semibold">@person.Name</div>
                                                    @if (!string.IsNullOrEmpty(person.Title))
                                                    {
                                                        <div class="text-muted small">@person.Title</div>
                                                    }
                                                    @if (!string.IsNullOrEmpty(person.Organization))
                                                    {
                                                        <div class="text-muted small">@person.Organization</div>
                                                    }
                                                    <div class="badge bg-secondary mt-1">@person.Confidence% confidence</div>
                                                </div>
                                            }
                                        </div>
                                    </div>
                                </div>
                            }

                            @if (Model.ProcessedData.Emails.Any())
                            {
                                <div class="accordion-item">
                                    <h2 class="accordion-header">
                                        <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#emailsCollapse">
                                            <i class="fa-solid fa-envelope me-2"></i>Email Addresses (@Model.ProcessedData.Emails.Count)
                                        </button>
                                    </h2>
                                    <div id="emailsCollapse" class="accordion-collapse collapse" data-bs-parent="#dataAccordion">
                                        <div class="accordion-body">
                                            @foreach (var email in Model.ProcessedData.Emails)
                                            {
                                                <div class="data-item">
                                                    <div class="fw-semibold">@email.Email</div>
                                                    @if (!string.IsNullOrEmpty(email.Context))
                                                    {
                                                        <div class="text-muted small">@email.Context</div>
                                                    }
                                                </div>
                                            }
                                        </div>
                                    </div>
                                </div>
                            }

                            @if (Model.ProcessedData.Tables.Any())
                            {
                                <div class="accordion-item">
                                    <h2 class="accordion-header">
                                        <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#tablesCollapse">
                                            <i class="fa-solid fa-table me-2"></i>Tables (@Model.ProcessedData.Tables.Count)
                                        </button>
                                    </h2>
                                    <div id="tablesCollapse" class="accordion-collapse collapse" data-bs-parent="#dataAccordion">
                                        <div class="accordion-body">
                                            @foreach (var table in Model.ProcessedData.Tables)
                                            {
                                                <div class="mb-4">
                                                    <h6 class="fw-semibold">@table.Title</h6>
                                                    <div class="table-responsive">
                                                        <table class="table table-sm table-bordered">
                                                            <thead class="table-light">
                                                                <tr>
                                                                    @foreach (var header in table.Headers)
                                                                    {
                                                                        <th>@header</th>
                                                                    }
                                                                </tr>
                                                            </thead>
                                                            <tbody>
                                                                @foreach (var row in table.Rows)
                                                                {
                                                                    <tr>
                                                                        @foreach (var cell in row)
                                                                        {
                                                                            <td>@cell</td>
                                                                        }
                                                                    </tr>
                                                                }
                                                            </tbody>
                                                        </table>
                                                    </div>
                                                </div>
                                            }
                                        </div>
                                    </div>
                                </div>
                            }
                        </div>
                    </div>
                }
                else
                {
                    <!-- Info Panel -->
                    <div class="docai-card p-4">
                        <h6 class="fw-semibold mb-3">
                            <i class="fa-solid fa-circle-info me-2 text-docai"></i>Multi-Agent Processing Pipeline
                        </h6>
                        <div class="docai-step mb-3">
                            <div class="docai-step-number">1</div>
                            <div class="docai-step-content">
                                <h6>PDF Reader Agent</h6>
                                <p class="mb-0">Extracts raw text and analyzes document structure and quality.</p>
                            </div>
                        </div>
                        <div class="docai-step mb-3">
                            <div class="docai-step-number">2</div>
                            <div class="docai-step-content">
                                <h6>Analyzer Agent</h6>
                                <p class="mb-0">Identifies persons, emails, and tables using AI-powered extraction.</p>
                            </div>
                        </div>
                        <div class="docai-step mb-0">
                            <div class="docai-step-number">3</div>
                            <div class="docai-step-content">
                                <h6>Validator Agent</h6>
                                <p class="mb-0">Applies business rules to validate extracted data quality.</p>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>
</section>

<form id="processForm" method="post" asp-page-handler="Process" style="display:none;">
    <input type="hidden" name="fileName" id="processFileName" />
</form>

@section Scripts {
<script src="~/js/upload-process.js"></script>
}