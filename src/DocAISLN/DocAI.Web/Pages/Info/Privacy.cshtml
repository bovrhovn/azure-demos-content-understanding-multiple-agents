@page
@model PrivacyModel
@{
    ViewData["Title"] = "Privacy Policy";
}

<section class="docai-hero" style="padding: 3rem 0 4rem;">
    <div class="container-xl">
        <div class="docai-hero-badge">
            <i class="fa-solid fa-shield-halved"></i> Privacy &amp; Data
        </div>
        <h1 class="mb-2">Privacy Policy</h1>
        <p class="lead mb-0">How we handle your data in this demo application.</p>
    </div>
</section>

<section class="py-5">
    <div class="container-xl">
        <div class="row justify-content-center">
            <div class="col-lg-8">
                <div class="docai-card p-4 p-md-5">

                    <h4 class="fw-semibold mb-3">
                        <i class="fa-solid fa-circle-info text-docai me-2"></i>About This Application
                    </h4>
                    <p class="text-muted">
                        This is an open-source demo application built on Azure AI Foundry and related Azure services.
                        It is intended for demonstration and educational purposes only.
                    </p>

                    <hr class="my-4"/>

                    <h4 class="fw-semibold mb-3">
                        <i class="fa-solid fa-database text-docai me-2"></i>Data Collection
                    </h4>
                    <p class="text-muted">
                        This demo application does not collect or store personal data. Documents submitted for processing
                        are sent directly to Azure AI services for analysis and are not retained beyond the duration of
                        the processing request.
                    </p>

                    <hr class="my-4"/>

                    <h4 class="fw-semibold mb-3">
                        <i class="fa-brands fa-microsoft text-docai me-2"></i>Azure Services
                    </h4>
                    <p class="text-muted">
                        This application uses the following Azure services, each of which has its own privacy policy:
                    </p>
                    <ul class="list-unstyled">
                        <li class="mb-2">
                            <a href="https://learn.microsoft.com/azure/ai-services/document-intelligence/overview"
                               target="_blank" rel="noopener noreferrer" class="text-decoration-none">
                                <i class="fa-solid fa-arrow-up-right-from-square me-1 text-docai"></i>
                                Azure AI Document Intelligence
                            </a>
                        </li>
                        <li class="mb-2">
                            <a href="https://learn.microsoft.com/azure/ai-foundry/what-is-ai-foundry"
                               target="_blank" rel="noopener noreferrer" class="text-decoration-none">
                                <i class="fa-solid fa-arrow-up-right-from-square me-1 text-docai"></i>
                                Azure AI Foundry
                            </a>
                        </li>
                        <li class="mb-2">
                            <a href="https://learn.microsoft.com/azure/ai-services/agents/overview"
                               target="_blank" rel="noopener noreferrer" class="text-decoration-none">
                                <i class="fa-solid fa-arrow-up-right-from-square me-1 text-docai"></i>
                                Azure AI Agent Service
                            </a>
                        </li>
                    </ul>

                    <hr class="my-4"/>

                    <h4 class="fw-semibold mb-3">
                        <i class="fa-brands fa-github text-docai me-2"></i>Open Source
                    </h4>
                    <p class="text-muted mb-0">
                        This project is open source and licensed under the MIT License. You can inspect all source code at
                        <a href="https://github.com/bovrhovn/azure-demos-content-understanding-multiple-agents"
                           target="_blank" rel="noopener noreferrer">
                            GitHub
                        </a>.
                    </p>
                </div>
            </div>
        </div>
    </div>
</section>
